\ExplSyntaxOn
% Dispatch into different commands based on the language code
\cs_new:Nn \__dispatch_color:n
  {
    \str_case:nn {#1}
      {
        {L} {Black}
        {I} {RoyalBlue}
        {A} {RedOrange}
        {M} {Black}
        {S} {RoyalBlue}
        {T} {RedOrange}
      }
    % Black
  }

\cs_new:Nn \__dispatch_tfont:n
  {
    \str_case:nn {#1}
      {
        {L} {\sffamily\upshape\mdseries}
        {I} {\rmfamily\upshape\bfseries}
        {A} {\ttfamily\upshape\mdseries}
        {M} {\sffamily\upshape\mdseries}
        {S} {\rmfamily\upshape\bfseries}
        {T} {\ttfamily\upshape\mdseries}
      }
  }

\ifpdftex
  \cs_new:Nn \__dispatch_mfont:n
    {
      \str_case:nn {#1}
        {
          {L} {\mathsf}
          {I} {\mathbf}
          {A} {\mathtt}
          {M} {\mathsf}
          {S} {\mathbf}
          {T} {\mathtt}
        }
    }

  \cs_new:Nn \__dispatch_gfont:n
    {
      \str_case:nn {#1}
        {
          {L} {
            \upshape\mdseries
            \renewcommand\textgreekfontmap{
              {phv/*/*}{U/psy/*/*}
              {*/bx/n}{U/eur/b/n}
              {*/b/n}{U/eur/b/n}
              {*/*/n}{U/eur/m/n}
              {*/*/it}{OML/*/*/*}
            }
          }
          {I} {
            \rmfamily\upshape\bfseries
          }
          {A} {
            \upshape\mdseries
            \renewcommand\textgreekfontmap{
              {eur/*/*}{U/eur/*/*}
              {phv/*/*}{U/psy/*/*}
            }
          }
          {M} {
            \upshape\mdseries
            \renewcommand\textgreekfontmap{
              {phv/*/*}{U/psy/*/*}
              {*/bx/n}{U/eur/b/n}
              {*/b/n}{U/eur/b/n}
              {*/*/n}{U/eur/m/n}
              {*/*/it}{OML/*/*/*}
            }
          }
          {S} {\rmfamily\upshape\bfseries}
          {T} {
            \upshape\mdseries
            \renewcommand\textgreekfontmap{
              {eur/*/*}{U/eur/*/*}
              {phv/*/*}{U/psy/*/*}
            }
          }
        }
    }
\else
  \cs_new:Nn \__dispatch_mfont:n
    {
      \str_case:nn {#1}
        {
          {L} {\symsfup}
          {I} {\symbfup}
          {A} {\symtt}
          {M} {\symsfup}
          {S} {\symbfup}
          {T} {\symtt}
        }
    }
\fi

\cs_new:Nn \__dispatch_name:n
  {
    \str_case:nn {#1}
      {
        {L} {\LAM}
        {I} {\IMP}
        {A} {\ASM}
        {M} {\MET}
        {S} {\SRC}
        {T} {\TGT}
      }
  }

