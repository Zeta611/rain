\WithSuffix\newcommand\SRC*{\SRC\nobreakdash-\hspace{0pt}}
\WithSuffix\newcommand\TGT*{\TGT\nobreakdash-\hspace{0pt}}

\NewDocumentCommand\Intp{ s m m d<> }
  {
    \IfBooleanTF{#1}
      {\smash{\Ltext{#2}{I}_{\Lname{#2}}\IfValueTF{#4}{^{#4\mskip1mu\Lname{#3}}}{^{\Lname{#3}}}}}
      {\Ltext{#2}{I}_{\Lname{#2}}\IfValueTF{#4}{^{#4\mskip1mu\Lname{#3}}}{^{\Lname{#3}}}}
  }

\ifpdftex
  % Workaround to get bold greek
  \NewDocumentCommand\Conc{ m d<> }
    {\Lgreek{#1}{\textgamma}\IfValueT{#2}{^{#2}}}

  \NewDocumentCommand\Abst{ m d<> }
    {\Lgreek{#1}{\textalpha}\IfValueT{#2}{^{#2}}}

  \NewDocumentCommand\Stt{ s m d<> }
    {
      \IfBooleanTF{#1}
        {
          \smash{\Lmath{#2}{\Lgreek{#2}{\textsigma}\IfValueT{#3}{^{#3}}}}
        }
        {
          \Lmath{#2}{\Lgreek{#2}{\textsigma}\IfValueT{#3}{^{#3}}}
        }
    }
\else
  \NewDocumentCommand\Conc{ m d<> }
    {\Lmath{#1}{\gamma}\IfValueT{#2}{^{#2}}}

  \NewDocumentCommand\Abst{ m d<> }
    {\Lmath{#1}{\alpha}\IfValueT{#2}{^{#2}}}

  \NewDocumentCommand\Stt{ m d<> }
    {\Lmath{#1}{\sigma}\IfValueT{#2}{^{#2}}}
\fi

