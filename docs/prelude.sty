\ExplSyntaxOn
\DeclarePairedDelimiter\__sem\llbracket\rrbracket
\NewDocumentCommand \Sem { s o m m d<> }
  {
    \mathcolor { \__dispatch_color:n {#3} }
    {
      \IfBooleanTF {#1}
        { \__sem* { \__dispatch_mfont:n {#3} {\ifblank{#4}{\,\cdot\,}{#4}} } }
        {
          \IfNoValueTF {#2}
            { \__sem { \__dispatch_mfont:n {#3} {\ifblank{#4}{\,\cdot\,}{#4}} } }
            { \__sem[#2] { \__dispatch_mfont:n {#3} {\ifblank{#4}{\,\cdot\,}{#4}} } }
        }
      \IfValueT {#5} { \sp{#5} }
    }
  }

\DeclarePairedDelimiter\__enc\lceil\rceil
\ProvideDocumentCommand \Enc { s o m m m } {}
\newcommand\IncludeEnc{
  \RenewDocumentCommand \Enc { s o m m m }
    {
      \mathcolor { \__dispatch_color:n {##3} }
      {
        \IfBooleanTF {##1}
          { \__enc* { \__dispatch_mfont:n {##3} {\ifblank{##5}{\,\cdot\,}{##5}} } }
          {
            \IfNoValueTF {##2}
              { \__enc { \__dispatch_mfont:n {##3} {\ifblank{##5}{\,\cdot\,}{##5}} } }
              { \__enc[##2] { \__dispatch_mfont:n {##3} {\ifblank{##5}{\,\cdot\,}{##5}} } }
          }
        \sb{\Ltext{##3}{\Lname{##3}}}
        \sp{\Ltext{##4}{\Lname{##4}}}
      }
    }
}
\IncludeEnc

